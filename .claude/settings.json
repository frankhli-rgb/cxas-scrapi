{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".agents/skills/agent-foundry/hooks/post-eval-run.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".agents/skills/agent-foundry/hooks/post-agent-update.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".agents/skills/agent-foundry/hooks/post-callback-write.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
